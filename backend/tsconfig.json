{
  "compilerOptions": {
    "target": "ES2020",          // or ES2019/ES2022
    "module": "CommonJS",        // or "ESNext" if ESM
    "lib": ["ES2020"],
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true
  }
}
